---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import PublicationCard from "@/components/PublicationCard.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import getPublicationsByKeyword from "@/utils/getPublicationsByKeyword";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const publications = await getCollection("publications");
  const tags = getUniqueTags(posts, publications);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;

const publications = await getCollection("publications");
const tagPublications = getPublicationsByKeyword(publications, tag);
---

<Layout title={`Tag: ${tagName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`Tag:`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`All the articles with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>

    <section>
      <h2 class="inline-block border-b-2 border-border pb-0.5 text-lg font-semibold">Posts</h2>
      <ul>
        {page.data.map(data => <Card {...data} />)}
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="inline-block border-b-2 border-border pb-0.5 text-lg font-semibold">Publications</h2>
      <ul>
        {tagPublications.map(pub => <PublicationCard {...pub} />)}
      </ul>
    </section>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
