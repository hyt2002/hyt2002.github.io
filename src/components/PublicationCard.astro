---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPublicationPath } from "@/utils/getPath";
import { SITE } from "@/config";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"publications">;

const { variant: Heading = "h3", id, data, filePath } = Astro.props;
const { title, authors, venue, pubDate, tldr, keywords, links, highlight, highlightLabel } =
  data;

const LINK_LABELS: Record<string, string> = {
  pdf: "PDF",
  arxiv: "arXiv",
  code: "Code",
  project: "Homepage",
  doi: "DOI",
  slides: "Slides",
};
---

<li class="my-6">
  <div class="flex flex-wrap items-start gap-2">
    <Heading class="text-lg font-semibold leading-snug">
      <a
        href={getPublicationPath(id, filePath)}
        class="text-accent decoration-dashed underline-offset-4 hover:underline"
      >
        {title}
      </a>
    </Heading>
    {
      highlight && (
        <span class="mt-0.5 shrink-0 rounded border border-accent/50 px-1.5 py-0.5 text-xs font-medium text-accent">
          {highlightLabel ?? "Highlight"}
        </span>
      )
    }
  </div>

  <p class="mt-1 text-sm text-foreground/70">
    {
      authors.map((author, i) => (
        <span>
          {i > 0 && <span>, </span>}
          {author === SITE.author ? (
            <strong class="font-semibold text-foreground">{author}</strong>
          ) : (
            author
          )}
        </span>
      ))
    }
  </p>

  <p class="mt-1 text-sm italic text-foreground/60">
    {venue}, {pubDate.getFullYear()}
  </p>

  {
    tldr && (
      <p class="mt-2 text-sm leading-relaxed text-foreground/80">
        <span class="font-semibold">TL;DR</span> {tldr}
      </p>
    )
  }

  {
    keywords && keywords.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {keywords.map(kw => (
          <a
            href={`/tags/${slugifyStr(kw)}`}
            class="rounded border border-keyword/40 px-2 py-0.5 text-xs font-medium text-keyword hover:bg-keyword hover:text-background transition-colors"
          >
            {kw}
          </a>
        ))}
      </div>
    )
  }

  {
    links && Object.keys(links).length > 0 && (
      <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1">
        {(Object.entries(links) as [string, string][]).map(([key, href]) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-bold text-accent underline decoration-2 underline-offset-2 hover:opacity-75"
          >
            {LINK_LABELS[key] ?? key}
          </a>
        ))}
      </div>
    )
  }
</li>
